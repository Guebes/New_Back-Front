datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique
  senha String
  cargo String @default("Operador") 
}

model Produto {
  id    Int    @id @default(autoincrement())
  nome  String
  qtd   Int
  preco String 
}